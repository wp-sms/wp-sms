{
  "name": "veronalabs/wp-sms",
  "description": "SMS & MMS Notifications, 2FA, OTP, and Integrations with E-Commerce and Form Builders",
  "type": "wordpress-plugin",
  "license": "GPL-2.0+",
  "authors": [
    {
      "name": "VeronaLabs",
      "email": "dev@veronalabs.com",
      "homepage": "https://veronalabs.com"
    }
  ],
  "require-dev": {
    "veronalabs/wp-scoper": "^0.1.0-beta"
  },
  "autoload": {
    "psr-4": {
      "WP_SMS\\": "src/"
    }
  },
  "extra": {
    "wp-scoper": {
      "namespace_prefix": "WP_SMS\\Dependencies",
      "packages": [],
      "target_directory": "src/Dependencies",
      "exclude_directories": ["views", "templates", "resources", "public"]
    }
  },
  "scripts": {
    "test": [
      "PATH=$(composer global config bin-dir --absolute --quiet --testdox):$PATH phpunit"
    ]
  },
  "minimum-stability": "beta",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "veronalabs/wp-scoper": true
    }
  }
}
