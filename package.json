{
  "name": "wp-sms",
  "version": "1.0.0",
  "license": "GPLv3",
  "scripts": {
    "build": "npm run build:blocks && npm run build:scripts && npm run build:sass && npm run build:dashboard",
    "build:blocks": "wp-scripts build --webpack-src-dir=public/src/blocks --output-path=public/blocks && rm -rf public/blocks/dev",
    "build:scripts": "webpack --config webpack.scripts.config.js",
    "build:sass": "sass public/src/scss/front-styles.scss:public/css/front-styles.css public/src/scss/mail.scss:public/css/mail.css public/src/admin/admin.scss:public/css/admin.css --style=compressed --no-source-map",
    "build:dashboard": "vite build",
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev:blocks\" \"npm run dev:scripts\" \"npm run dev:sass\" \"npm run dev\"",
    "dev:blocks": "wp-scripts start --webpack-copy-php --webpack-src-dir=public/src/blocks --output-path=public/blocks",
    "dev:scripts": "webpack --config webpack.scripts.config.js --watch",
    "dev:sass": "sass --watch public/src/scss/front-styles.scss:public/css/front-styles.css public/src/scss/mail.scss:public/css/mail.css public/src/admin/admin.scss:public/css/admin.css --style=compressed --no-source-map",
    "preview": "vite preview",
    "test": "jest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "wp:docker:start": "wp-env start",
    "wp:docker:stop": "wp-env stop",
    "wp:docker:clean": "wp-env clean all",
    "wp:docker:logs": "wp-env logs",
    "wp:docker:cli": "wp-env run cli"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.24.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@wordpress/components": "^23.8.0",
    "@wordpress/dependency-extraction-webpack-plugin": "^5.6.0",
    "@wordpress/env": "^10.28.0",
    "@wordpress/scripts": "^30.17.0",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^10.0.0",
    "concurrently": "^7.5.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.94.1",
    "tailwindcss": "^3.4.0",
    "terser": "^5.44.1",
    "terser-webpack-plugin": "^5.3.10",
    "vite": "^5.4.0",
    "vite-plugin-compression": "^0.5.1",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "fast-deep-equal": "^3.1.3",
    "lucide-react": "^0.400.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.2.0"
  }
}
