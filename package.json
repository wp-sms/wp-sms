{
  "name": "wp-sms",
  "version": "1.0.0",
  "license": "GPLv3",
  "scripts": {
    "build": "wp-scripts build --webpack-src-dir=public/src/blocks --output-path=public/blocks && rm -rf public/blocks/dev",
    "start": "concurrently \"wp-scripts start --webpack-copy-php --webpack-src-dir=public/src/blocks --output-path=public/blocks\" \"npm run dev\"",
    "sass-compile": "concurrently \"sass public/src/scss/front-styles.scss:public/css/front-styles.css --style=compressed --no-source-map\" \"sass public/src/scss/mail.scss:public/css/mail.css --style=compressed --no-source-map\" \"sass public/src/admin/admin.scss:public/css/admin.css --style=compressed --no-source-map\" \"sass public/src/scss/onboarding/main.scss:public/css/onboarding.min.css --style=compressed --no-source-map\"",
    "watch-sass": "concurrently \"sass public/src/scss/front-styles.scss:public/css/front-styles.css --watch --style=compressed --no-source-map\" \"sass public/src/scss/mail.scss:public/css/mail.css --watch --style=compressed --no-source-map\" \"sass public/src/admin/admin.scss:public/css/admin.css --watch --style=compressed --no-source-map\" \"sass public/src/scss/onboarding/main.scss:public/css/onboarding.min.css --watch --style=compressed --no-source-map\"",
    "js-compile": "webpack --config webpack.scripts.config.js",
    "watch-js": "webpack --config webpack.scripts.config.js --watch",
    "watch": "concurrently \"npm run watch-sass\" \"npm run watch-js\"",
    "dev": "npm run watch",
    "dashboard:dev": "vite --config vite.config.js",
    "dashboard:build": "vite build --config vite.config.js",
    "dashboard:preview": "vite preview --config vite.config.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "wp:docker:start": "wp-env start",
    "wp:docker:stop": "wp-env stop",
    "wp:docker:clean": "wp-env clean all",
    "wp:docker:logs": "wp-env logs",
    "wp:docker:cli": "wp-env run cli",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:subscribers": "playwright test tests/e2e/tests/subscribers/",
    "e2e:groups": "playwright test tests/e2e/tests/groups/",
    "e2e:send-sms": "playwright test tests/e2e/tests/send-sms/",
    "e2e:outbox": "playwright test tests/e2e/tests/outbox/",
    "e2e:report": "playwright show-report e2e-report",
    "e2e:codegen": "playwright codegen http://localhost:8888",
    "e2e:a11y": "playwright test --grep @accessibility",
    "e2e:a11y:local": "dotenv -e .env.e2e.local -- playwright test --grep @accessibility"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@babel/core": "^7.0.0",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.24.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@wordpress/components": "^23.8.0",
    "@wordpress/dependency-extraction-webpack-plugin": "^5.6.0",
    "@wordpress/env": "^10.28.0",
    "@wordpress/scripts": "^30.17.0",
    "autoprefixer": "^10.4.0",
    "babel-loader": "^10.0.0",
    "concurrently": "^7.5.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.4.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "sass": "^1.94.1",
    "tailwindcss": "^3.4.0",
    "terser": "^5.44.1",
    "terser-webpack-plugin": "^5.3.10",
    "vite": "^5.4.0",
    "vite-plugin-compression": "^0.5.1",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "fast-deep-equal": "^3.1.3",
    "lucide-react": "^0.400.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwind-merge": "^2.2.0"
  }
}
