# WordPress.org Distribution Ignore File
# Files and directories listed here will be excluded from the plugin ZIP

# ============================================
# Version Control & CI/CD
# ============================================
/.wordpress-org
/.git
/.github
/bin

# ============================================
# Node.js & Build Tools
# ============================================
/node_modules
/dist
package.json
package-lock.json
pnpm-lock.yaml
postcss.config.js
babel.config.js

# ============================================
# Testing
# ============================================
/tests
phpunit.xml.dist
.phpunit.result.cache
jest.config.js
jest.setup.js
playwright.config.js
.wp-env.json
.env.e2e.example

# ============================================
# Frontend Build Configuration
# ============================================
tailwind.config.js
vite.config.js
vite.config.entries.mjs
bundle-analysis.html

# ============================================
# PHP Build Configuration
# ============================================
composer.json
composer.lock
codeception.dist.yml

# ============================================
# Source Files (only built files needed)
# ============================================
/resources/blocks
/resources/entries
/resources/fonts
/resources/images
/resources/json
/resources/react
/resources/scss
/resources/vendor-css
/resources/vendor-js
/vendor

# ============================================
# Documentation (not needed in production)
# ============================================
README.md
CHANGELOG.md
CONTRIBUTING.md
security.md

# ============================================
# Environment & Configuration Files
# ============================================
.distignore
.editorconfig
.gitignore
.gitattributes
.DS_Store
.gulpfile.js

# ============================================
# AI & IDE Tools
# ============================================
/.claude
/.cursor
/.vscode
.mcp.json
CLAUDE.md
AGENTS.md
